<section
  class="bloqio-faq"
  data-icon-style="{{ block.settings.icon_style }}"
  data-icon-pos="{{ block.settings.icon_position }}"
  style="
    --bloqio-pad-y: {{ block.settings.padding_y }}px;
    --bloqio-radius: {{ block.settings.radius }}px;
    --bloqio-border: {{ block.settings.border_color }};
    --bloqio-border-w: {{ block.settings.border_width }}px;
    --bloqio-bg: {{ block.settings.bg_color }};
    --bloqio-text: {{ block.settings.text_color }};
    --bloqio-accent: {{ block.settings.accent_color }};

    --bloqio-item-bg: {{ block.settings.item_bg }};
    --bloqio-item-gap: {{ block.settings.item_gap }}px;
    --bloqio-item-pad-x: {{ block.settings.item_pad_x }}px;
    --bloqio-item-pad-y: {{ block.settings.item_pad_y }}px;

    --bloqio-q-size: {{ block.settings.q_size }}px;
    --bloqio-a-size: {{ block.settings.a_size }}px;

    --bloqio-icon-size: {{ block.settings.icon_size }}px;
    --bloqio-icon-stroke: {{ block.settings.icon_stroke }};
    --bloqio-icon-color: {{ block.settings.icon_color }};
    --bloqio-icon-bg: {{ block.settings.icon_bg }};
    --bloqio-icon-bg-on: {% if block.settings.icon_bg_enable %}1{% else %}0{% endif %};
    --bloqio-icon-radius: {{ block.settings.icon_radius }}px;
    --bloqio-icon-pad: {{ block.settings.icon_pad }}px;
  "
>
  <div class="bloqio-faq__inner">
    {% if block.settings.heading != blank %}
      <div class="bloqio-faq__header">
        <h2 class="bloqio-faq__heading">{{ block.settings.heading | escape }}</h2>
        {% if block.settings.subheading != blank %}
          <p class="bloqio-faq__subheading">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="bloqio-faq__list">
      {% for i in (1..6) %}
        {% assign q_id = 'q_' | append: i %}
        {% assign a_id = 'a_' | append: i %}
        {% assign q = block.settings[q_id] %}
        {% assign a = block.settings[a_id] %}

        {% if q != blank and a != blank %}
          <details class="bloqio-faq__item" {% if block.settings.open_first and forloop.first %}open{% endif %}>
            <summary class="bloqio-faq__summary">
              <span class="bloqio-faq__q">{{ q | escape }}</span>

              {%- assign icon_img = block.settings.icon_image -%}
              {%- assign icon_img_open = block.settings.icon_image_open -%}

              <span class="bloqio-faq__icon" aria-hidden="true">
                {%- if icon_img != blank -%}
                  <img class="bloqio-faq__icon-img bloqio-faq__icon-img--closed"
                       src="{{ icon_img | image_url: width: 96 }}"
                       alt="" loading="lazy"
                       width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}">
                  {%- if icon_img_open != blank -%}
                    <img class="bloqio-faq__icon-img bloqio-faq__icon-img--open"
                         src="{{ icon_img_open | image_url: width: 96 }}"
                         alt="" loading="lazy"
                         width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}">
                  {%- endif -%}
                {%- else -%}
                  {%- if block.settings.icon_style == 'chevron' -%}
                    <svg class="bloqio-faq__icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                      <path d="M6 9l6 6 6-6" stroke="currentColor" />
                    </svg>
                  {%- else -%}
                    <svg class="bloqio-faq__icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                      <path d="M5 12h14" stroke="currentColor" />
                      <path class="bloqio-icon__v" d="M12 5v14" stroke="currentColor" />
                    </svg>
                  {%- endif -%}
                {%- endif -%}
              </span>
            </summary>

            <div class="bloqio-faq__a">
              {{ a }}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloqio FAQ PRO",
  "target": "section",
  "stylesheet": "bloqio-faq-accordion.css",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Preguntas frecuentes" },
    { "type": "richtext", "id": "subheading", "label": "Subtítulo", "default": "<p>Resolvemos tus dudas más comunes</p>" },

    { "type": "checkbox", "id": "open_first", "label": "Abrir la primera pregunta", "default": true },

    { "type": "header", "content": "Contenido (hasta 6)" },
    { "type": "text", "id": "q_1", "label": "Pregunta 1", "default": "¿En cuánto tiempo llega mi pedido?" },
    { "type": "richtext", "id": "a_1", "label": "Respuesta 1", "default": "<p>Normalmente llega en 24–72 horas en principales ciudades.</p>" },
    { "type": "text", "id": "q_2", "label": "Pregunta 2", "default": "¿Qué métodos de pago aceptan?" },
    { "type": "richtext", "id": "a_2", "label": "Respuesta 2", "default": "<p>Tarjeta, transferencia y métodos locales según tu checkout.</p>" },
    { "type": "text", "id": "q_3", "label": "Pregunta 3", "default": "¿Tienen garantía?" },
    { "type": "richtext", "id": "a_3", "label": "Respuesta 3", "default": "<p>Sí. Escríbenos y te ayudamos.</p>" },
    { "type": "text", "id": "q_4", "label": "Pregunta 4", "default": "—" },
    { "type": "richtext", "id": "a_4", "label": "Respuesta 4", "default": "<p>—</p>" },
    { "type": "text", "id": "q_5", "label": "Pregunta 5", "default": "—" },
    { "type": "richtext", "id": "a_5", "label": "Respuesta 5", "default": "<p>—</p>" },
    { "type": "text", "id": "q_6", "label": "Pregunta 6", "default": "—" },
    { "type": "richtext", "id": "a_6", "label": "Respuesta 6", "default": "<p>—</p>" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_y", "label": "Padding vertical", "min": 0, "max": 60, "step": 4, "default": 24 },
    { "type": "range", "id": "radius", "label": "Radio (bordes)", "min": 0, "max": 28, "step": 2, "default": 12 },
    { "type": "range", "id": "border_width", "label": "Grosor del borde", "min": 0, "max": 6, "step": 1, "default": 1 },
    { "type": "range", "id": "item_gap", "label": "Espaciado entre items", "min": 0, "max": 32, "step": 2, "default": 10 },
    { "type": "range", "id": "item_pad_x", "label": "Padding horizontal item", "min": 10, "max": 44, "step": 2, "default": 18 },
    { "type": "range", "id": "item_pad_y", "label": "Padding vertical item", "min": 8, "max": 32, "step": 2, "default": 14 },

    { "type": "header", "content": "Colores" },
    { "type": "color", "id": "bg_color", "label": "Fondo sección", "default": "#ffffff" },
    { "type": "color", "id": "item_bg", "label": "Fondo item", "default": "#ffffff" },
    { "type": "color", "id": "border_color", "label": "Borde", "default": "#e6e6e6" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#111111" },
    { "type": "color", "id": "accent_color", "label": "Acento", "default": "#111111" },

    { "type": "header", "content": "Tipografía" },
    { "type": "range", "id": "q_size", "label": "Tamaño pregunta", "min": 14, "max": 24, "step": 1, "default": 16 },
    { "type": "range", "id": "a_size", "label": "Tamaño respuesta", "min": 12, "max": 20, "step": 1, "default": 14 },

    { "type": "header", "content": "Iconos" },
    { "type": "select", "id": "icon_style", "label": "Icono default", "default": "plus",
      "options": [
        { "value": "plus", "label": "+ / -" },
        { "value": "chevron", "label": "Chevron" }
      ]
    },
    { "type": "select", "id": "icon_position", "label": "Posición del icono", "default": "right",
      "options": [
        { "value": "right", "label": "Derecha" },
        { "value": "left", "label": "Izquierda" }
      ]
    },
    { "type": "image_picker", "id": "icon_image", "label": "Icono personalizado (cerrado)" },
    { "type": "image_picker", "id": "icon_image_open", "label": "Icono personalizado (abierto)" },
    { "type": "range", "id": "icon_size", "label": "Tamaño del icono", "min": 12, "max": 28, "step": 1, "default": 18 },
    { "type": "range", "id": "icon_stroke", "label": "Grosor del trazo", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "color", "id": "icon_color", "label": "Color del icono", "default": "#111111" },
    { "type": "checkbox", "id": "icon_bg_enable", "label": "Fondo detrás del icono", "default": true },
    { "type": "color", "id": "icon_bg", "label": "Color del fondo (icono)", "default": "#f3f3f3" },
    { "type": "range", "id": "icon_radius", "label": "Radio del fondo (icono)", "min": 0, "max": 24, "step": 2, "default": 16 },
    { "type": "range", "id": "icon_pad", "label": "Padding del fondo (icono)", "min": 0, "max": 14, "step": 1, "default": 6 }
  ]
}
{% endschema %}