{%- comment -%}Bloqio TopBar PRO — build messages string (Simple vs Avanzado){%- endcomment -%}
{%- assign bloqio_messages = '' -%}
{%- if block.settings.messages_mode == 'fields' -%}
  {%- assign bloqio_count = block.settings.messages_count | default: 3 | plus: 0 -%}
  {%- capture bloqio_msg_capture -%}
    {%- if bloqio_count >= 1 and block.settings.msg_1_text != blank -%}{{ block.settings.msg_1_icon }}: {{ block.settings.msg_1_text | strip }}|{%- endif -%}
    {%- if bloqio_count >= 2 and block.settings.msg_2_text != blank -%}{{ block.settings.msg_2_icon }}: {{ block.settings.msg_2_text | strip }}|{%- endif -%}
    {%- if bloqio_count >= 3 and block.settings.msg_3_text != blank -%}{{ block.settings.msg_3_icon }}: {{ block.settings.msg_3_text | strip }}|{%- endif -%}
    {%- if bloqio_count >= 4 and block.settings.msg_4_text != blank -%}{{ block.settings.msg_4_icon }}: {{ block.settings.msg_4_text | strip }}|{%- endif -%}
    {%- if bloqio_count >= 5 and block.settings.msg_5_text != blank -%}{{ block.settings.msg_5_icon }}: {{ block.settings.msg_5_text | strip }}|{%- endif -%}
  {%- endcapture -%}
  {%- assign bloqio_messages = bloqio_msg_capture | strip | remove_last: '|' -%}
{%- else -%}
  {%- assign bloqio_messages = block.settings.messages | strip -%}
{%- endif -%}

<div
  id="bloqio-topbar"
  class="bloqio-topbar"
  data-bloqio-sprite-url="{{ 'bloqio-icons.svg' | asset_url }}"
  data-enabled="{{ block.settings.enabled }}"
  data-sticky="{{ block.settings.sticky }}"
  data-rotate="{{ block.settings.rotate }}"
  data-rotate-seconds="{{ block.settings.rotate_seconds }}"
  data-dismiss="{{ block.settings.dismiss }}"
  data-remember-hours="{{ block.settings.remember_hours }}"
  data-hide-mobile="{{ block.settings.hide_mobile }}"
  data-hide-desktop="{{ block.settings.hide_desktop }}"
  data-icon-enabled="{{ block.settings.icon_enabled }}"
  data-icon-size="{{ block.settings.icon_size }}"
  data-icon-gap="{{ block.settings.icon_gap }}"
  data-icon-color="{{ block.settings.icon_color }}"
  data-countdown="{{ block.settings.countdown }}"
  data-countdown-in-rotation="{{ block.settings.countdown_in_rotation }}"
  data-countdown-end="{{ block.settings.countdown_year }}-{{ block.settings.countdown_month }}-{{ block.settings.countdown_day }} {{ block.settings.countdown_hour }}:{{ block.settings.countdown_minute }}"
  data-countdown-prefix="{{ block.settings.countdown_prefix | escape }}"
  data-countdown-suffix="{{ block.settings.countdown_suffix | escape }}"
  data-messages='{{ bloqio_messages | replace: "'", "&#39;" | replace: '"', '&quot;' }}'
  data-cta-style="{{ block.settings.cta_style }}"
  style="
    --bt-bg: {{ block.settings.bg }};
    --bt-text: {{ block.settings.text }};
    --bt-accent: {{ block.settings.accent }};
    --bt-h: {{ block.settings.height }}px;
    --bt-px: {{ block.settings.pad_x }}px;
    --bt-radius: {{ block.settings.radius }}px;
    --bt-icon-size: {{ block.settings.icon_size }}px;
    --bt-icon-gap: {{ block.settings.icon_gap }}px;
    --bt-icon-color: {{ block.settings.icon_color }};
    --bt-cta-bg: {{ block.settings.cta_bg }};
    --bt-cta-text: {{ block.settings.cta_text_color }};
    --bt-cta-border: {{ block.settings.cta_border_color }};
    --bt-cta-radius: {{ block.settings.cta_radius }}px;
    --bt-cta-px: {{ block.settings.cta_pad_x }}px;
    --bt-cta-py: {{ block.settings.cta_pad_y }}px;
  "
>
  <div class="bloqio-topbar__inner">
   
    <div class="bloqio-topbar__msg" aria-live="polite"></div>

    <a
      class="bloqio-topbar__cta {% if block.settings.cta_style == 'button' %}is-button{% else %}is-link{% endif %}"
      href="{{ block.settings.cta_url }}"
      {% if block.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
      {% if block.settings.cta_url == blank %}aria-disabled="true"{% endif %}
    >
      {{ block.settings.cta_text | escape }}
    </a>

    <button class="bloqio-topbar__x" type="button" aria-label="Cerrar" title="Cerrar">
      ×
    </button>
  </div>
</div>

{% schema %}
